@model QuickInvoiceSaaS.Models.LoginViewModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html dir="rtl" lang="ar">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>تسجيل الدخول - نظام الفواتير الذكي</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <style>
        body {
            background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0;
        }

        .login-card {
            background: white;
            border: none;
            border-radius: 15px;
            box-shadow: 0 10px 25px rgba(0,0,0,0.1);
            width: 100%;
            max-width: 420px;
            padding: 35px;
        }

        .brand-icon {
            font-size: 45px;
            text-align: center;
            margin-bottom: 10px;
        }

        .form-control:focus {
            border-color: #0d6efd;
            box-shadow: 0 0 0 0.25rem rgba(13, 110, 253, 0.15);
        }

        .btn-primary-custom {
            background-color: #0d6efd;
            border: none;
            padding: 12px;
            font-weight: bold;
            font-size: 16px;
            transition: 0.3s;
        }

            .btn-primary-custom:hover {
                background-color: #0b5ed7;
            }
    </style>
</head>
<body>

    <div class="login-card">
        <div class="brand-icon">🔐</div>
        <h3 class="text-center fw-bold text-dark mb-2">مرحباً بك مجدداً</h3>
        <p class="text-center text-secondary small mb-4">قم بتسجيل الدخول للوصول إلى لوحة تحكم شركتك</p>

        <form asp-action="Login" method="post">
            @if (!ViewData.ModelState.IsValid)
            {
                <div asp-validation-summary="ModelOnly" class="alert alert-danger p-2 small text-center" role="alert"></div>
            }

            <div class="mb-3">
                <label class="form-label small fw-bold text-secondary">البريد الإلكتروني</label>
                <input asp-for="Email" type="email" class="form-control form-control-lg" placeholder="name@company.com" required />
            </div>

            <div class="mb-4">
                <label class="form-label small fw-bold text-secondary">كلمة المرور</label>
                <input asp-for="Password" type="password" class="form-control form-control-lg" placeholder="••••••••" required />
            </div>

            <button type="submit" class="btn btn-primary btn-primary-custom w-100 rounded-3 mb-3">دخول آمن</button>
        </form>

        <hr class="text-muted my-3">

        <div class="text-center">
            <p class="small text-secondary mb-0">ليس لديك حساب لشركتك حتى الآن؟</p>
            <a asp-action="Register" class="text-decoration-none small fw-bold text-primary">أنشئ حساب شركة جديد الآن</a>
        </div>
    </div>

</body>
</html>