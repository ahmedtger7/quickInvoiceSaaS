@model QuickInvoiceSaaS.Models.RegisterViewModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html dir="rtl" lang="ar">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>تسجيل شركة جديدة - نظام الفواتير الذكي</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <style>
        body {
            background: linear-gradient(135deg, #f5f7fa 0%, #e2ebf0 100%);
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0;
        }

        .register-card {
            background: white;
            border: none;
            border-radius: 15px;
            box-shadow: 0 10px 25px rgba(0,0,0,0.1);
            width: 100%;
            max-width: 440px;
            padding: 35px;
        }

        .brand-icon {
            font-size: 45px;
            text-align: center;
            margin-bottom: 10px;
        }

        .form-control:focus {
            border-color: #198754;
            box-shadow: 0 0 0 0.25rem rgba(25, 135, 84, 0.15);
        }

        .btn-success-custom {
            background-color: #198754;
            border: none;
            padding: 12px;
            font-weight: bold;
            font-size: 16px;
            transition: 0.3s;
        }

            .btn-success-custom:hover {
                background-color: #146c43;
            }
    </style>
</head>
<body>

    <div class="register-card">
        <div class="brand-icon">🚀</div>
        <h3 class="text-center fw-bold text-dark mb-2">ابدأ منصتك اليوم</h3>
        <p class="text-center text-secondary small mb-4">أنشئ مساحة عمل مخصصة ومعزولة لفواتير شركتك</p>

        <form asp-action="Register" method="post">
            @if (!ViewData.ModelState.IsValid)
            {
                <div asp-validation-summary="ModelOnly" class="alert alert-danger p-2 small text-center" role="alert"></div>
            }

            <div class="mb-3">
                <label class="form-label small fw-bold text-secondary">البريد الإلكتروني للمسؤول</label>
                <input asp-for="Email" type="email" class="form-control form-control-lg" placeholder="admin@company.com" required />
            </div>

            <div class="mb-3">
                <label class="form-label small fw-bold text-secondary">معرف الشركة الفريد (Tenant ID)</label>
                <input asp-for="TenantId" class="form-control form-control-lg" placeholder="مثال: SUDANI-ONE أو Tiger" required />
                <div class="form-text text-muted small">سيتم عزل كافة فواتيرك وتأمينها تحت هذا المعرّف.</div>
            </div>

            <div class="mb-4">
                <label class="form-label small fw-bold text-secondary">كلمة المرور</label>
                <input asp-for="Password" type="password" class="form-control form-control-lg" placeholder="••••••••" required />
            </div>

            <button type="submit" class="btn btn-success btn-success-custom w-100 rounded-3 mb-3">إطلاق حساب الشركة</button>
        </form>

        <hr class="text-muted my-3">
        <div class="mb-3">
            <label class="form-label small fw-bold text-secondary">اختر خطة الاشتراك</label>
            <select asp-for="SubscriptionPlan" class="form-select form-control-lg">
                <option value="Free">🎁 الخطة المجانية (بحد أقصى 3 فواتير)</option>
                <option value="Premium">👑 الخطة المدفوعة Premium (فواتير غير محدودة)</option>
            </select>
        </div>

        <div class="text-center">
            <p class="small text-secondary mb-0">تمتلك حساباً بالفعل؟</p>
            <a asp-action="Login" class="text-decoration-none small fw-bold text-success">سجل دخولك من هنا</a>
        </div>
    </div>

</body>
</html>