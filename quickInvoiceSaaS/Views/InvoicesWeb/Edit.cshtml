@model QuickInvoiceSaaS.Models.Invoice

@{
    ViewData["Title"] = "تعديل الفاتورة";
}

<div class="card p-4 shadow-sm mx-auto" style="max-width: 500px; border-radius: 12px; margin-top: 40px; background: white;">
    <h3 class="text-center mb-4 text-primary">📝 تعديل بيانات الفاتورة</h3>

    <form asp-action="Edit" method="post">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
        <input type="hidden" asp-for="Id" />

        <div class="mb-3">
            <label class="form-label fw-bold small text-secondary">رقم الفاتورة:</label>
            <input asp-for="InvoiceNumber" class="form-control" required />
            <span asp-validation-for="InvoiceNumber" class="text-danger small"></span>
        </div>

        <div class="mb-3">
            <label class="form-label fw-bold small text-secondary">اسم العميل:</label>
            <input asp-for="ClientName" class="form-control" required />
            <span asp-validation-for="ClientName" class="text-danger small"></span>
        </div>

        <div class="d-flex gap-2 mt-4">
            <button type="submit" class="btn btn-primary flex-fill fw-bold">حفظ التعديلات</button>
            <a asp-action="Index" class="btn btn-secondary flex-fill">إلغاء والعودة</a>
        </div>
    </form>
</div>